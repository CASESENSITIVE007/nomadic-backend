    {
      "name": "Share",
      "item": [
        {
          "name": "Generate Share Link",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/api/share/trip/{{tripId}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"permissions\": \"view\",\n  \"expiresIn\": 30\n}"
            }
          }
        },
        {
          "name": "Get Shared Trip",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/share/trip/{{shareToken}}"
