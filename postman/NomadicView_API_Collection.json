      "key": "token",
      "value": "your_jwt_token_here",
      "type": "string"
    },
    {
      "key": "tripId",
      "value": "your_trip_id_here",
      "type": "string"
    },
    {
      "key": "placeId",
      "value": "your_place_id_here",
