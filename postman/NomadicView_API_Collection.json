          "name": "Generate Trip QR",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/share/trip/{{tripId}}/qr"
          }
        },
        {
          "name": "Invite User",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/api/share/trip/{{tripId}}/invite",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"friend@example.com\",\n  \"role\": \"editor\"\n}"
            }
          }
        }
